diff --git a/ios/SQLiteModule.swift b/ios/SQLiteModule.swift
index 15c784fb31629b1ab4b08a0f975b1f317985c433..3ea5df28d56665588d717eabb7a6ed87233a08d1 100644
--- a/ios/SQLiteModule.swift
+++ b/ios/SQLiteModule.swift
@@ -150,6 +150,15 @@ public final class SQLiteModule: Module {
         }
       }

+      // Cancels the in-flight statement on this connection. Runs on the JS
+      // thread (not moduleQueue) so the call doesn't queue behind the very
+      // statement it's trying to interrupt. exsqlite3_interrupt is documented
+      // as thread-safe and signals across threads — it returns immediately.
+      Function("interruptSync") { (database: NativeDatabase) in
+        guard !database.isClosed, let pointer = database.pointer else { return }
+        exsqlite3_interrupt(pointer)
+      }
+
       AsyncFunction("execAsync") { (database: NativeDatabase, source: String) in
         try exec(database: database, source: source)
       }.runOnQueue(moduleQueue)
@@ -467,7 +476,15 @@ public final class SQLiteModule: Module {
   private func finalize(statement: NativeStatement, database: NativeDatabase) throws {
     try maybeThrowForClosedDatabase(database)
     try maybeThrowForFinalizedStatement(statement)
-    if exsqlite3_finalize(statement.pointer) != SQLITE_OK {
+    let result = exsqlite3_finalize(statement.pointer)
+    // SQLITE_INTERRUPT (9) here re-reports a prior interruption of the
+    // statement's evaluation; per sqlite3_finalize() docs the statement is
+    // still finalized and resources released regardless of return code.
+    // Treating it as success prevents try/finally cleanup paths in
+    // SQLiteDatabase.{getAllAsync,runAsync,…} from masking the original
+    // interrupt rejection with a benign secondary error (which surfaces
+    // as an uncaught promise rejection during our suspension drain).
+    if result != SQLITE_OK && result != SQLITE_INTERRUPT {
       throw SQLiteErrorException(convertSqlLiteErrorToString(database))
     }
     statement.isFinalized = true
