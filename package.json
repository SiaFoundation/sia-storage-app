{
  "name": "siastorage",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "npm rebuild better-sqlite3",
    "lint": "oxlint . && oxfmt --check .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun --cwd packages/core test && bun --cwd packages/node-adapters test && bun --cwd apps/mobile test && bun --cwd apps/integration test && bun --cwd apps/cli test",
    "mobile:fresh": "bun --cwd apps/mobile fresh",
    "mobile:start": "bun --cwd apps/mobile start",
    "mobile:dev:ios:simulator": "bun --cwd apps/mobile dev:ios:simulator",
    "mobile:dev:ios:device": "bun --cwd apps/mobile dev:ios:device",
    "mobile:dev:android:emulator": "bun --cwd apps/mobile dev:android:emulator",
    "mobile:dev:android:device": "bun --cwd apps/mobile dev:android:device",
    "mobile:dev:ios:device:release": "bun --cwd apps/mobile dev:ios:device:release",
    "mobile:dev:android:device:release": "bun --cwd apps/mobile dev:android:device:release",
    "mobile:lint": "bun --cwd apps/mobile lint",
    "mobile:lint:fix": "bun --cwd apps/mobile lint:fix",
    "mobile:typecheck": "bun --cwd apps/mobile typecheck",
    "mobile:test": "bun --cwd apps/mobile test",
    "mobile:test:unit": "bun --cwd apps/mobile test:unit",
    "mobile:test:core": "bun --cwd apps/mobile test:core",
    "mobile:test:scripts": "bun --cwd apps/mobile test:scripts",
    "mobile:test:e2e:ios": "bun --cwd apps/mobile test:e2e:ios",
    "mobile:test:e2e:android": "bun --cwd apps/mobile test:e2e:android",
    "mobile:android": "bun --cwd apps/mobile android",
    "mobile:ios": "bun --cwd apps/mobile ios",
    "cli:lint": "bun --cwd apps/cli lint",
    "cli:typecheck": "bun --cwd apps/cli typecheck",
    "cli:test": "bun --cwd apps/cli test",
    "cli:test:e2e": "bun --cwd apps/cli test:e2e",
    "cli:test:all": "bun --cwd apps/cli test:all",
    "cli:build": "bun --cwd apps/cli build",
    "cli:build:darwin-arm64": "bun --cwd apps/cli build:darwin-arm64",
    "cli:build:darwin-x64": "bun --cwd apps/cli build:darwin-x64",
    "cli:build:linux-x64": "bun --cwd apps/cli build:linux-x64",
    "cli:build:linux-arm64": "bun --cwd apps/cli build:linux-arm64",
    "cli:build:windows-x64": "bun --cwd apps/cli build:windows-x64",
    "cli:link": "bun --cwd apps/cli link",
    "changeset": "knope document-change",
    "release": "knope release",
    "migration:create": "bun scripts/create-migration.ts",
    "knip": "knip --include files,unlisted"
  },
  "dependencies": {},
  "devDependencies": {
    "knip": "6.3.0",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0"
  },
  "patchedDependencies": {
    "react-native-fs@2.20.0": "patches/react-native-fs@2.20.0.patch",
    "expo-sqlite@55.0.10": "patches/expo-sqlite@55.0.10.patch"
  }
}
