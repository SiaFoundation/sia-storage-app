# Expo
.expo/
web-build/
expo-env.d.ts

# Native (generated by expo prebuild) — anchored to apps/mobile so local
# Expo modules under modules/<name>/{ios,android}/ stay tracked.
/android/
/ios/
.kotlin/
# Gradle build output. Git already ignores it via the root .gitignore; repeated
# here so oxfmt — which reads only this directory's .gitignore — skips it too.
modules/*/android/build/

# Build cache
.build-cache/

# Signing
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
android-release.keystore

# Fastlane: releaseAndroid.ts generates the Play "What's new" changelog per release
fastlane/metadata/android/*/changelogs/

# Metro
.metro-health-check*

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# Environment
.env
.env.*
!.env.example
!.env.test

# E2E
test/e2e/.maestro/
